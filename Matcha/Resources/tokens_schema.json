{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://matcha.nyan.dev/tokens_schema.json",
    "title": "Matcha Theme Schema",
    "description": "Validates Matcha theme JSON files. Defines color seeds, optional color overrides, font seeds, spring physics, and global font scale.",
    "type": "object",
    "required": ["name", "colorSeeds", "fonts"],
    "additionalProperties": false,
    "properties": {
        "name": {
            "type": "string",
            "description": "Human-readable theme name (e.g. 'Light', 'Dark', 'HighContrast').",
            "minLength": 1
        },
        "extends": {
            "type": "string",
            "description": "Base theme name to inherit from. All tokens not explicitly set are inherited from the base.",
            "minLength": 1
        },
        "colorSeeds": {
            "$ref": "#/$defs/colorSeedsObject"
        },
        "colors": {
            "type": "object",
            "description": "Per-token color overrides applied after tonal palette generation. Keys must be valid ColorToken names (lower camelCase).",
            "patternProperties": {
                "^[a-z][a-zA-Z0-9]+$": { "$ref": "#/$defs/cssColor" }
            },
            "additionalProperties": false
        },
        "fonts": {
            "$ref": "#/$defs/fontSeedsObject"
        },
        "spring": {
            "$ref": "#/$defs/springObject"
        },
        "fontScale": {
            "type": "number",
            "description": "Global font scaling factor (0.5 to 3.0).",
            "minimum": 0.5,
            "maximum": 3.0
        }
    },
    "$defs": {
        "cssColor": {
            "type": "string",
            "description": "CSS hex color: #RRGGBB or #AARRGGBB.",
            "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$"
        },
        "colorSeedsObject": {
            "type": "object",
            "description": "Seed colors for tonal palette generation. Keys must match the ColorSeeds names (lower camelCase).",
            "required": [
                "colorPrimaryBase",
                "colorPrimaryNavBase",
                "colorSuccessBase",
                "colorWarningBase",
                "colorErrorBase",
                "colorTextBase",
                "colorBgBase"
            ],
            "properties": {
                "colorPrimaryBase": { "$ref": "#/$defs/cssColor" },
                "colorPrimaryNavBase": { "$ref": "#/$defs/cssColor" },
                "colorSuccessBase": { "$ref": "#/$defs/cssColor" },
                "colorWarningBase": { "$ref": "#/$defs/cssColor" },
                "colorErrorBase": { "$ref": "#/$defs/cssColor" },
                "colorTextBase": { "$ref": "#/$defs/cssColor" },
                "colorBgBase": { "$ref": "#/$defs/cssColor" }
            },
            "additionalProperties": false
        },
        "fontSeedsObject": {
            "type": "object",
            "description": "Font seed values for the theme. Keys match FontRole enumeration.",
            "required": [
                "fontWeightRegular",
                "fontWeightMedium",
                "fontWeightBold",
                "fontItalic",
                "fontLineHeight",
                "fontLetterSpacing",
                "fontSizeBase"
            ],
            "properties": {
                "fontWeightRegular": { "type": "number", "minimum": 100, "maximum": 900 },
                "fontWeightMedium": { "type": "number", "minimum": 100, "maximum": 900 },
                "fontWeightBold": { "type": "number", "minimum": 100, "maximum": 900 },
                "fontItalic": { "type": "boolean" },
                "fontLineHeight": { "type": "number", "minimum": 0.5, "maximum": 3.0 },
                "fontLetterSpacing": { "type": "number" },
                "fontSizeBase": { "type": "number", "minimum": 6, "maximum": 72 }
            },
            "additionalProperties": false
        },
        "springObject": {
            "type": "object",
            "description": "Spring dynamics parameters for physics-based animations.",
            "required": ["mass", "stiffness", "damping"],
            "properties": {
                "mass": { "type": "number", "minimum": 0.01 },
                "stiffness": { "type": "number", "minimum": 1.0 },
                "damping": { "type": "number", "minimum": 0.0 }
            },
            "additionalProperties": false
        }
    }
}